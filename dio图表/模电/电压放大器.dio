        <mxCell id="64" value="$$u_i=u_{s}\cdot\frac{R_{i}}{R_{i} + R_{s}}$$" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;" parent="1" vertex="1">
